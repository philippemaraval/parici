PORT=3000
NODE_ENV=development

# Required in production: JWT signing secret
SECRET_KEY=change-me-to-a-long-random-string

# Frontend origin allow-list
FRONTEND_URL=https://your-frontend.example
# Optional: comma-separated list of additional origins
CORS_ALLOWED_ORIGINS=https://preview-one.example,https://preview-two.example

# Optional admin maintenance routes (disabled by default)
ENABLE_ADMIN_ROUTES=false
ADMIN_API_KEY=change-me-admin-key

# Optional: comma-separated usernames with editor rights (without DB role change)
EDITOR_USERNAMES=friend_username

# Push notification settings
# If omitted, Camino generates keys in DB on first boot.
VAPID_SUBJECT=mailto:noreply@camino.app
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Daily push reminder schedule
PUSH_REMINDER_HOUR=10
PUSH_REMINDER_MINUTE=0
PUSH_REMINDER_TIMEZONE=Europe/Paris
